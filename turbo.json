{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "prebuild",
        "^build"
      ],
      "outputs": [
        "output-file.txt",
        "dist/**"
      ]
    },
    "prebuild": {},
    "lint": {},
    "check-types": {},
    "start:dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "interruptible": false,
      "cache": false
    },
    "app-a#start:dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "interruptible": true,
      "cache": false
    }
  }
}
